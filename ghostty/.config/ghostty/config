# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

# -----------------
# theme = noisy-boy
# -----------------

# near-black purple armor background
background = 0f0518

# text and cursor using the glowing ambers and oranges
foreground = f2b705
cursor-color = f28705

# selection using the plum and yellow
selection-background = 73265e
selection-foreground = f2b705

# ansi color palette mapped to your 5 image colors

# black (mapped to the deep violet and plum)
palette = 0=#5a0273
palette = 8=#73265e

# red (mapped to the burnt orange)
palette = 1=#d95204
palette = 9=#d95204

# green (mapped to the bright orange)
palette = 2=#f28705
palette = 10=#f28705

# yellow (mapped to the golden yellow)
palette = 3=#f2b705
palette = 11=#f2b705

# blue (mapped to the plum)
palette = 4=#73265e
palette = 12=#73265e

# magenta (mapped to the deep violet)
palette = 5=#5a0273
palette = 13=#5a0273

# cyan (mapped to the bright orange)
palette = 6=#f28705
palette = 14=#f28705

# white (mapped to the golden yellow)
palette = 7=#f2b705
palette = 15=#f2b705

# ---

font-family = "Mononoki Nerd Font"
font-size = 14
cursor-style = block
cursor-invert-fg-bg = true
cursor-style-blink = true
cursor-click-to-move = true
mouse-hide-while-typing = true
background-opacity = 0.80
background-blur = true
window-padding-x = 8
window-padding-y = 8
# term = xterm-kitty
shell-integration-features = no-cursor
